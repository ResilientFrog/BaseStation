#include <WiFi.h>
#include <WebServer.h>
#include <Wire.h>
#include <SparkFun_u-blox_GNSS_v3.h>
#include <LiquidCrystal_I2C.h> //Click here to get the library: http://librarymanager/All#SparkFun_SerLCD
#include "wi-fi/wiFiConnectionController.h"
#include "baseRTK/baseRTKController.h"


LiquidCrystal_I2C lcd(0x27, 16, 2);  
// ============ Configuration Constants ============
const char *AP_SSID     = "ESP32_Config_Node";
const char *AP_PASSWORD = "ESP123**"; 
const uint32_t BAUD_RATE = 9600;

// ============ Global Objects ============
SFE_UBLOX_GNSS myGNSS;
WebServer server(80);

const char index_html[] PROGMEM = R"rawliteral(
<!DOCTYPE html>
<html>
<head>
  <title>Base Station Config</title>
  <meta name='viewport' content='width=device-width, initial-scale=1'>
  <style>
    body { font-family: Arial; margin: 20px; line-height: 1.6; }
    .container { max-width: 400px; background: #f4f4f4; padding: 20px; border-radius: 10px; box-shadow: 0 0 10px rgba(0,0,0,0.1); }
    .input-group { margin-bottom: 15px; }
    label { display: block; font-weight: bold; }
    input[type='text'], input[type='number'], select { width: 100%; padding: 8px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; }
    input[type='submit'] { background: #4CAF50; color: white; border: none; padding: 10px; cursor: pointer; width: 100%; border-radius: 4px; font-size: 16px; }
    input[type='submit']:hover { background: #45a049; }
    .hidden { display: none; }
    h2 { color: #333; }
  </style>
</head>
<body>
  <div class='container'>
    <h2>Base Station Control</h2>
    <form action='/update' method='POST'>
      
      <div class='input-group'>
        <label>Mode:</label>
        <select name='mode' id='modeSelect' onchange='toggleFields()'>
          <option value='Survey'>Survey-In</option>
          <option value='Fixed'>Fixed Position</option>
        </select>
      </div>

      <!-- Survey-In Fields -->
      <div id='surveyFields'>
        <div class='input-group'>
          <label>Accuracy (meters):</label>
          <input type='number' step='0.1' name='acc' value='2.0'>
        </div>
        <div class='input-group'>
          <label>Minimum Time (seconds):</label>
          <input type='number' name='time' value='60'>
        </div>
      </div>

      <!-- Fixed Position Fields -->
      <div id='fixedFields' class='hidden'>
        <div class='input-group'>
          <label>Latitude:</label>
          <input type='text' name='lat' placeholder='e.g. 45.1234567'>
        </div>
        <div class='input-group'>
          <label>Longitude:</label>
          <input type='text' name='lon' placeholder='e.g. -75.1234567'>
        </div>
        <div class='input-group'>
          <label>Altitude (m):</label>
          <input type='text' name='alt' placeholder='e.g. 150.5'>
        </div>
      </div>

      <input type='submit' value='Apply Settings'>
    </form>
  </div>

  <script>
    function toggleFields() {
      var mode = document.getElementById('modeSelect').value;
      document.getElementById('surveyFields').classList.toggle('hidden', mode !== 'Survey');
      document.getElementById('fixedFields').classList.toggle('hidden', mode !== 'Fixed');
    }
  </script>
</body>
</html>
)rawliteral";

void handleRoot() {
  server.send(200, "text/html", index_html);
}

void checkRTKStatus() {
  byte fixType = myGNSS.getFixType(); 
  Serial.print(F("Fix: "));
  if (fixType == 0) Serial.println(F("No Fix"));
  else if (fixType == 1) Serial.println(F("Dead Reckoning"));
  else if (fixType == 2) Serial.println(F("2D Fix"));
  else if (fixType == 3) Serial.println(F("3D Fix"));
  else if (fixType == 5) Serial.println(F("** RTK FLOAT **"));
  else if (fixType == 6) Serial.println(F("== RTK FIXED =="));

  byte SIV = myGNSS.getSIV();
  Serial.print(F("Satellites: "));
  Serial.println(SIV);
}

void handleUpdate() {
  String mode = server.arg("mode");
  bool success = false;

  if (mode == "Survey") {
    float acc = server.arg("acc").toFloat();
    uint32_t time = server.arg("time").toInt();
    
    // Command the F9P to begin Survey-In
    success = myGNSS.enableSurveyModeFull(time, acc);
    
    if (success) {
      Serial.printf("Survey Started: Time=%d, Acc=%.2f\n", time, acc);
      server.send(200, "text/html", "<h1>Survey Started</h1><a href='/'>Back</a>");
    }
  } 
  else if (mode == "Fixed") {
    // Note: Use double for Lat/Lon for high precision
    double lat = server.arg("lat").toDouble();
    double lon = server.arg("lon").toDouble();
    float alt = server.arg("alt").toFloat(); // Altitude in meters
    
    // Convert to the units required by u-blox (degrees * 10^-7 and mm)
    int32_t latFixed = (int32_t)(lat * 10000000);
    int32_t lonFixed = (int32_t)(lon * 10000000);
    int32_t altFixed = (int32_t)(alt * 1000); // meters to mm

    // Set static position (Tmode3 = Fixed)
    success = myGNSS.setStaticPosition(latFixed, lonFixed, altFixed, true, VAL_LAYER_RAM);
    if (success) {
      Serial.printf("Fixed Position Set: %f, %f, %f\n", lat, lon, alt);
      server.send(200, "text/html", "<h1>Fixed Position Applied</h1><a href='/'>Back</a>");
    }
  }

  if (!success) {
    server.send(500, "text/plain", "Failed to apply settings to GNSS.");
  }
}

void setup() {
  Serial.begin(BAUD_RATE);
  delay(1000);

  // Initialize the LCD
  lcd.init();
  lcd.backlight(); // Turn on the backlight
  
  lcd.setCursor(0, 0);
  lcd.print("Address 0x27 OK");
  delay(2000);
  lcd.clear();
  // Setup WiFi Access Point
  WiFi.softAP(AP_SSID, AP_PASSWORD);
  server.on("/", HTTP_GET, handleRoot);
  server.on("/update", HTTP_POST, handleUpdate);
  server.begin();

  Wire.begin();
  if (myGNSS.begin() == false) {
    Serial.println(F("GNSS not detected. Check I2C wiring."));
    while (1);
  }

  // Set I2C port to output UBX and RTCM3
  myGNSS.setI2COutput(COM_TYPE_UBX | COM_TYPE_RTCM3); 

  // Enable necessary RTCM messages for a Base Station
  myGNSS.newCfgValset(); 
  myGNSS.addCfgValset(UBLOX_CFG_MSGOUT_RTCM_3X_TYPE1005_I2C, 1);
  myGNSS.addCfgValset(UBLOX_CFG_MSGOUT_RTCM_3X_TYPE1074_I2C, 1);
  myGNSS.addCfgValset(UBLOX_CFG_MSGOUT_RTCM_3X_TYPE1084_I2C, 1);
  myGNSS.addCfgValset(UBLOX_CFG_MSGOUT_RTCM_3X_TYPE1094_I2C, 1);
  myGNSS.addCfgValset(UBLOX_CFG_MSGOUT_RTCM_3X_TYPE1124_I2C, 1);
  myGNSS.addCfgValset(UBLOX_CFG_MSGOUT_RTCM_3X_TYPE1230_I2C, 10);
  myGNSS.sendCfgValset();

  Serial.println(F("System Ready at 192.168.4.1"));
}

void loop() {
  server.handleClient();

  static unsigned long lastCheck = 0;
  if (millis() - lastCheck > 2000) {
    
    lastCheck = millis();
    checkRTKStatus();
    Serial.println(myGNSS.getSurveyInActive());
    Serial.println(myGNSS.getSurveyStatus(1000));
    // Check if Survey-In is currently running
    if (myGNSS.getSurveyStatus(1000)) {
      if (myGNSS.getSurveyInActive()) {

        float accuracy = myGNSS.getSurveyInMeanAccuracy();
        uint32_t obsTime = myGNSS.getSurveyInObservationTimeFull();
         // Clear the screen for the new update

        // --- Serial Monitor Output ---
        Serial.print(F("Surveying... Acc: "));
        Serial.print(accuracy);
        Serial.print(F("m, Time: "));
        Serial.println(obsTime);

        // Line 1: Accuracy
        lcd.setCursor(0, 0); // Start at Col 0, Row 0
        lcd.print("Acc: ");
        lcd.print(accuracy, 2); // Print with 2 decimal places
        lcd.print("m");

        // Line 2: Time
        lcd.setCursor(0, 1); // Move to Col 0, Row 1
        lcd.print("Time: ");
        lcd.print(obsTime);
        lcd.print("s");
      } 
      else if (myGNSS.getSurveyInValid()) {
        Serial.println(F("STATUS: Base Position Valid (Survey Finished or Fixed Set)"));
      }
    }
  }
}